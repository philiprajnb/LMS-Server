# Server Configuration
PORT=3000
NODE_ENV=production

# MongoDB Configuration
# Use your MongoDB Atlas cluster URL
MONGODB_URI=mongodb+srv://username:password@cluster-name.mongodb.net/lms-server?retryWrites=true&w=majority

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-replace-this
JWT_EXPIRES_IN=7d

# Bcrypt Configuration
BCRYPT_SALT_ROUNDS=12

# CORS Configuration
# For production, list your frontend domain(s)
ALLOWED_ORIGINS=https://lms-admin-blush-alpha.vercel.app,http://localhost:3002

# Rate Limiting
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=5

# Admin Bootstrap
# Use this key to promote users to admin via the promote-admin script
BOOTSTRAP_ADMIN_KEY=your-secure-random-bootstrap-key